# Google Gemini API key — used server-side only for the AI concierge and ops briefings.
# Get one free at https://aistudio.google.com/app/apikey
# PitchPilot degrades gracefully to a deterministic engine when this is absent.
GEMINI_API_KEY=your_key_here

# Optional — override the model chain, tried in order, comma-separated.
# The free tier counts quota per project PER MODEL, so extra models add both
# resilience and allowance. Defaults to:
#   gemini-2.5-flash,gemini-flash-latest,gemini-2.5-flash-lite,gemini-flash-lite-latest
# GEMINI_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite

# Canonical site origin for SEO metadata and social previews.
# Netlify sets URL automatically on deploy; set this only for a custom domain.
# NEXT_PUBLIC_SITE_URL=https://your-site.netlify.app
